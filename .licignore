# GoLic ignore file -- https://github.com/Bugs5382/golic
# Ignore everything...
*

# ...but inject the Apache 2.0 header into these source types:
!*.ts
!*.tsx
!*.js
!*.mts
!*.mjs
!*.cjs

# ...even when they live in subdirectories:
!*/

# Never the build output, deps, caches, or generated docs:
/node_modules/**
**/node_modules/**
/dist/**
**/dist/**
/coverage/**
**/coverage/**

# Connect-ES stubs bridged in from the api repo's generated TS output (see the
# bridge-copy note atop each file under src/gen) -- regenerated there, copied
# here until a published package replaces the copy.
/src/gen/**
